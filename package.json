{
  "name": "template-backend-nest",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "prepare:env": "powershell -ExecutionPolicy Bypass -File setup.ps1 || bash setup.sh",
    "build": "run-s ci:generate build:tsdown",
    "start:tsx:watch": "tsx watch --env-file=.env --no-deprecation src/main.ts",
    "start:dev": "run-s start:tsx:watch",
    "start:worker": "tsx --env-file=.env src/main.ts",
    "start:prod": "node --env-file=.env --enable-source-maps dist/main.js",
    "start:prod:docker": "node --enable-source-maps dist/main.js",
    "build:tsc": "tsc",
    "build:tsgo": "tsgo",
    "build:tsdown": "tsdown --config ./tsdown.config.ts",
    "lint:src:biome": "biome lint --write src",
    "lint:prisma:biome": "biome lint --write prisma",
    "format:src:biome": "biome format --write src",
    "format:prisma:biome": "biome format --write prisma",
    "check:src:biome": "biome check --write src",
    "check:prisma:biome": "biome check --write prisma",
    "db:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:dev:default": "prisma migrate dev --name creating_database_models",
    "db:migrate:reset": "prisma migrate reset --force",
    "db:seed": "prisma db seed",
    "db:reset": "run-s db:generate db:migrate:reset db:seed",
    "db:migrate-deploy": "prisma migrate deploy",
    "db:deploy": "run-s db:migrate-deploy db:generate db:seed",
    "ci:generate": "run-p db:generate",
    "ci:lint": "run-p check:prisma:biome check:src:biome",
    "ci:format": "run-p check:prisma:biome check:src:biome",
    "ci:build": "run-s ci:generate build:tsgo build:tsdown",
    "sentry:upload": "sentry-cli sourcemaps inject ./dist && sentry-cli sourcemaps upload ./dist",
    "combo": "pnpm i && pnpm prepare:env && docker compose down -v && docker compose up -d --force-recreate && node -e \"setTimeout(() => console.log('✅ Banco pronto!'), 3000)\" && pnpm prisma migrate reset --force && pnpm prisma generate && pnpm prisma migrate dev && pnpm prisma db seed && pnpm start:dev"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.4.4",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "7.8.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.21.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.4.3",
    "zod-validation-error": "^5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcryptjs": "^3.0.0",
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "@types/passport": "^1.0.17",
    "@types/passport-jwt": "^4.0.1",
    "globals": "^17.0.0",
    "npm-run-all": "^4.1.5",
    "prisma": "^7.8.0",
    "source-map-support": "^0.5.21",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
