# Nginx — reverse proxy para a API (role-hoje backend).
# Copie para /etc/nginx/sites-available/api.rolehoje.com, ajuste o server_name,
# crie o symlink em sites-enabled, teste com `nginx -t` e recarregue.
# Depois rode: sudo certbot --nginx -d api.rolehoje.com  (ele adiciona o bloco 443/TLS automaticamente)

server {
    listen 80;
    server_name api.rolehoje.com;   # <-- troque pelo seu subdomínio da API

    # Limite de upload (avatares). Ajuste se precisar.
    client_max_body_size 10M;

    location / {
        proxy_pass http://127.0.0.1:3333;   # <-- APP_PORT do backend
        proxy_http_version 1.1;

        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # SSE (stream de eventos em tempo real): não bufferizar e manter conexão viva.
        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
    }
}
