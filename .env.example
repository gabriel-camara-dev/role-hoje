# Defina o ambiente
NODE_ENV=development
LOG_LEVEL=debug
PROJECT_NAME=backend-template-nest

# App
APP_NAME="Backend Template Nest"
APP_PORT=3000
# String secreta para assinar tokens JWT (use uma string longa e aleatória, mínimo 60 caracteres, ex: openssl rand -base64 32)
JWT_SECRET=
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
FRONTEND_URL=http://localhost:5173
HASH_SALT_ROUNDS=12
# URL do projeto no Sentry para monitoramento de erros (obtenha em sentry.io)
SENTRY_DSN=

# Comando de inicialização
COMMAND="pnpm combo"

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=template_backend
POSTGRES_PORT=5432
SCHEMA=public

# REDIS:
REDIS_CONTAINER_NAME=redis-backend-template-nest

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# URLs de conexão
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/template_backend?schema=public"

# Resend
# API key gerada no painel da Resend (https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# Email do remetente verificado na Resend (ex: noreply@seudominio.com)
RESEND_FROM_EMAIL=noreply@seudominio.com
