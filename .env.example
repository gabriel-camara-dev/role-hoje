# Defina o ambiente
NODE_ENV=development
LOG_LEVEL=debug
PROJECT_NAME=role-hoje

# App
APP_NAME=role-hoje
APP_PORT=3000
# String secreta para assinar tokens JWT (mínimo 60 caracteres). Gere uma nova com: openssl rand -hex 48
JWT_SECRET=CHANGE_ME_gere_um_segredo_aleatorio_de_no_minimo_60_caracteres_aqui
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
FRONTEND_URL=http://localhost:5173
HASH_SALT_ROUNDS=12
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3333/sessions/google/callback
AVATAR_ENCRYPTION_SECRET=change-me-to-a-long-random-secret-with-at-least-32-characters
AVATAR_STORAGE_DIR=storage/avatars
# URL do projeto no Sentry para monitoramento de erros (obtenha em sentry.io)
SENTRY_DSN=

# Comando de inicialização
COMMAND="pnpm combo"

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=template_backend_nest
POSTGRES_PORT=5432
SCHEMA=public

# REDIS:
REDIS_CONTAINER_NAME=redis-backend-template-nest

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# URLs de conexão
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/template_backend_nest?schema=public"

# Resend
# API key gerada no painel da Resend (https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxx
# Email do remetente verificado na Resend (ex: noreply@seudominio.com)
RESEND_FROM_EMAIL=xxxxxxxxxxxxxxxxxxxx
