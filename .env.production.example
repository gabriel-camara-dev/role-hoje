# ============================================================
# .env de PRODUÇÃO — copie para `.env` no servidor e preencha.
# Troque rolehoje.com pelo SEU domínio. NUNCA commite o .env real.
# ============================================================

NODE_ENV=production
LOG_LEVEL=info
PROJECT_NAME=role-hoje

# App
APP_NAME=role-hoje
APP_PORT=3333
# Gere: openssl rand -hex 48
JWT_SECRET=
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
# Origem EXATA do frontend em produção (usado no CORS e nos links de e-mail)
FRONTEND_URL=https://rolehoje.com
HASH_SALT_ROUNDS=12

# Google OAuth (Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.rolehoje.com/sessions/google/callback

# Avatares (NÃO mude AVATAR_ENCRYPTION_SECRET depois que houver uploads).
# Gere: openssl rand -hex 32
AVATAR_ENCRYPTION_SECRET=
AVATAR_STORAGE_DIR=storage/avatars

# Sentry (opcional, recomendado)
SENTRY_DSN=

# PostgreSQL (containers do docker-compose.prod.yml)
POSTGRES_CONTAINER_NAME=role-hoje-postgres
POSTGRES_USER=rolehoje
POSTGRES_PASSWORD=
POSTGRES_DB=role_hoje
POSTGRES_HOST_PORT=5432

# Redis (com senha!)
REDIS_CONTAINER_NAME=role-hoje-redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_HOST_PORT=6379

# Conexão do Prisma (use os mesmos usuário/senha/db acima; host 127.0.0.1)
DATABASE_URL="postgresql://rolehoje:SENHA_DO_POSTGRES@127.0.0.1:5432/role_hoje?schema=public"

# Resend (domínio verificado no painel da Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@rolehoje.com
