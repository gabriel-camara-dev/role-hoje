enum NotificationType {
  GROUP_INVITE
  GROUP_INVITE_ACCEPTED
  GROUP_JOIN_REQUEST
  GROUP_MEMBER_ACCEPTED
  FRIEND_REQUEST
  FRIEND_ACCEPTED

  @@schema("social")
}

model Notification {
  id        Int              @id @default(autoincrement())
  publicId  String           @unique @default(uuid(7)) @map("public_id")
  userId    Int              @map("user_id")
  actorId   Int?             @map("actor_id")
  type      NotificationType
  title     String
  body      String?
  data      Json?
  readAt    DateTime?        @map("read_at")
  createdAt DateTime         @default(now()) @map("created_at")

  user  User  @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  actor User? @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([userId, readAt, createdAt], name: "idx_notification_user_read")
  @@map("notifications")
  @@schema("social")
}
