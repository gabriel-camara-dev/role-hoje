enum GroupPrivacy {
  PUBLIC
  PRIVATE

  @@schema("groups")
}

enum GroupMemberRole {
  OWNER
  MODERATOR
  MEMBER

  @@schema("groups")
}

enum GroupMemberStatus {
  ACTIVE
  PENDING
  BLOCKED

  @@schema("groups")
}

enum VoteStatus {
  ACTIVE
  CANCELLED

  @@schema("places")
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  BLOCKED

  @@schema("social")
}

enum ModerationReportStatus {
  OPEN
  RESOLVED
  DISMISSED

  @@schema("moderation")
}

model Place {
  id               Int      @id @default(autoincrement())
  publicId         String   @unique @default(uuid(7)) @map("public_id")
  googlePlaceId    String   @unique @map("google_place_id")
  name             String
  formattedAddress String   @map("formatted_address")
  latitude         Decimal  @db.Decimal(10, 7)
  longitude        Decimal  @db.Decimal(10, 7)
  city             String?
  state            String?
  country          String?
  photoUrl         String?  @map("photo_url")
  websiteUrl       String?  @map("website_url")
  mapsUrl          String?  @map("maps_url")
  isActive         Boolean  @default(true) @map("is_active")
  createdById      Int?     @map("created_by_id")
  createdBy        User?    @relation(fields: [createdById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  votes   PlaceVote[]
  reports ModerationReport[]

  @@index([city, state], name: "idx_place_city_state")
  @@index([latitude, longitude], name: "idx_place_coordinates")
  @@map("places")
  @@schema("places")
}

model PlaceVote {
  id        Int        @id @default(autoincrement())
  publicId  String     @unique @default(uuid(7)) @map("public_id")
  day       DateTime   @db.Date
  note      String?
  status    VoteStatus @default(ACTIVE)
  scopeKey  String     @default("global") @map("scope_key")
  userId    Int        @map("user_id")
  placeId   Int        @map("place_id")
  groupId   Int?       @map("group_id")
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  place     Place      @relation(fields: [placeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  group     Group?     @relation(fields: [groupId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  @@unique([userId, placeId, scopeKey, day], name: "uq_vote_user_place_scope_day")
  @@index([day, status], name: "idx_vote_day_status")
  @@index([placeId, day], name: "idx_vote_place_day")
  @@index([groupId, day], name: "idx_vote_group_day")
  @@map("place_votes")
  @@schema("places")
}

model Group {
  id          Int          @id @default(autoincrement())
  publicId    String       @unique @default(uuid(7)) @map("public_id")
  name        String
  slug        String       @unique
  description String?
  privacy     GroupPrivacy @default(PUBLIC)
  city        String?
  state       String?
  createdById Int          @map("created_by_id")
  createdBy   User         @relation(fields: [createdById], references: [id], onDelete: Cascade, onUpdate: Cascade)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  members GroupMember[]
  votes   PlaceVote[]

  @@index([privacy, city], name: "idx_group_privacy_city")
  @@map("groups")
  @@schema("groups")
}

model GroupMember {
  id        Int               @id @default(autoincrement())
  groupId   Int               @map("group_id")
  userId    Int               @map("user_id")
  role      GroupMemberRole   @default(MEMBER)
  status    GroupMemberStatus @default(ACTIVE)
  group     Group             @relation(fields: [groupId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")

  @@unique([groupId, userId], name: "uq_group_member")
  @@index([userId, status], name: "idx_group_member_user_status")
  @@map("group_members")
  @@schema("groups")
}

model Friendship {
  id          Int              @id @default(autoincrement())
  requesterId Int              @map("requester_id")
  addresseeId Int              @map("addressee_id")
  status      FriendshipStatus @default(PENDING)
  requester   User             @relation("FriendshipRequester", fields: [requesterId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  addressee   User             @relation("FriendshipAddressee", fields: [addresseeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  @@unique([requesterId, addresseeId], name: "uq_friendship_pair")
  @@index([addresseeId, status], name: "idx_friendship_addressee_status")
  @@map("friendships")
  @@schema("social")
}

model ModerationReport {
  id         Int                    @id @default(autoincrement())
  publicId   String                 @unique @default(uuid(7)) @map("public_id")
  reason     String
  status     ModerationReportStatus @default(OPEN)
  reporterId Int                    @map("reporter_id")
  placeId    Int?                   @map("place_id")
  reporter   User                   @relation(fields: [reporterId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  place      Place?                 @relation(fields: [placeId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  createdAt  DateTime               @default(now()) @map("created_at")
  updatedAt  DateTime               @updatedAt @map("updated_at")

  @@index([status, createdAt], name: "idx_moderation_report_status_date")
  @@map("moderation_reports")
  @@schema("moderation")
}
