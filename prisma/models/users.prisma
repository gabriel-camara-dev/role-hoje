enum UserRole {
  ADMIN
  DEFAULT

  @@schema("users")
}

model User {
  id            Int       @id @default(autoincrement())
  publicId      String    @unique @default(uuid(7)) @map("public_id")
  name          String
  username      String    @unique
  email         String    @unique
  passwordHash  String?   @map("password_hash")
  googleId      String?   @unique @map("google_id")
  avatarEncryptedPath String?   @map("avatar_encrypted_path")
  avatarIv            String?   @map("avatar_iv")
  avatarAuthTag       String?   @map("avatar_auth_tag")
  avatarMimeType      String?   @map("avatar_mime_type")
  avatarOriginalName  String?   @map("avatar_original_name")
  avatarUpdatedAt     DateTime? @map("avatar_updated_at")
  loginAttempts Int       @default(0) @map("login_attempts")
  lastLogin     DateTime? @map("last_login")
  role          UserRole  @default(DEFAULT)

  token          String?   @unique
  tokenExpiresAt DateTime? @map("token_expires_at")
  emailVerifiedAt DateTime? @map("email_verified_at")
  emailVerificationTokenHash String? @unique @map("email_verification_token_hash")
  emailVerificationTokenExpiresAt DateTime? @map("email_verification_token_expires_at")

  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  passwordChangedAt DateTime? @map("password_changed_at")

  authenticationAudits AuthenticationAudit[]
  createdPlaces        Place[]
  placeVotes           PlaceVote[]
  createdGroups        Group[]
  groupMembers         GroupMember[]
  requestedFriendships Friendship[] @relation("FriendshipRequester")
  receivedFriendships  Friendship[] @relation("FriendshipAddressee")
  moderationReports    ModerationReport[]

  @@index([name], name: "idx_user_name")
  @@index([token], name: "idx_user_token")
  @@index([emailVerificationTokenHash], name: "idx_user_email_verification_token")
  @@map("users")
  @@schema("users")
}
